{
  "version": "1.0",
  "keep": {
    "maxFiles": 250,
    "maxLineCount": 25000,
    "allowedDirs": ["src", "bin", "tests", "docs", "scripts"]
  },
  "packs": {
    "discoveryRoot": "packs",
    "maxSize": 5000000
  },
  "gitsafe": {
    "denylist": [".env", "id_rsa", "secrets", "token", "private", "credentials"],
    "maxBytes": 2000000
  }
}
