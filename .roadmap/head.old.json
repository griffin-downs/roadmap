    "sk-dir-integration": {
      "id": "sk-dir-integration",
      "desc": "Establish `.roadmap/spec/` as spec-kit workspace. Create directory structure, add README with conventions (file naming: `<dag-id>-spec.md`, `<dag-id>-plan.md`, `<dag-id>-tasks.md`, `<dag-id>-selected.json`, `<dag-id>-gallery.json`). Add backward-compat note for `.specify/` migration. Produces: `.roadmap/spec/README.md`, `.roadmap/spec/.gitkeep`",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "idempotent": true
    },
    "sk-validation-rules": {
      "id": "sk-validation-rules",
      "desc": "Implement `validateSpecKitPlan(planPath)` and `validateSpecKitTasks(tasksPath)` in `src/spec-kit/validation.ts`. Plan validation: required sections present, node IDs referenced. Tasks validation: every node has id + description + produces + consumes + dependencies + validate, node IDs valid (no spaces/special chars), all dependencies exist (no orphans), DAG is acyclic, init/term nodes exist. Returns `ValidationResult` with errors + warnings. Depends: sk-dir-integration. Produces: `src/spec-kit/validation.ts`, `tests/spec-kit/validation.test.ts`",
      "produces": [],
      "consumes": [],
      "deps": [
        "sk-dir-integration"
      ],
      "validate": [],
      "idempotent": true
    },
    "sk-agent-brief-gen": {
      "id": "sk-agent-brief-gen",
      "desc": "Implement `generateAgentBrief(options)` in `src/spec-kit/agent-brief.ts`. Takes `dagId`, `intent`, `roadmapPosition` (Orientation), `specKitWorkspace` path. Produces markdown + YAML frontmatter brief with: current batch + position, node produces/consumes, intent statement, spec file locations, next commands to run, error handling tips. Depends: sk-dir-integration. Produces: `src/spec-kit/agent-brief.ts`, `tests/spec-kit/agent-brief.test.ts`",
      "produces": [],
      "consumes": [],
      "deps": [
        "sk-dir-integration"
      ],
      "validate": [],
      "idempotent": true
    },
    "sk-brief-template-doc": {
      "id": "sk-brief-template-doc",
      "desc": "Write agent brief template at `docs/AGENT-SPEC-KIT-BRIEF.md`. Covers: when to use `/speckit.specify` vs roadmap node descriptions, how to feed plan output into roadmap import, error recovery (plan fails, import rejects), intent formulation guidance with examples. Depends: sk-agent-brief-gen. Produces: `docs/AGENT-SPEC-KIT-BRIEF.md`",
      "produces": [],
      "consumes": [],
      "deps": [
        "sk-agent-brief-gen"
      ],
      "validate": [],
      "idempotent": true
    },
    "sk-workflow-doc": {
      "id": "sk-workflow-doc",
      "desc": "Write workflow documentation at `docs/SPEC-KIT-ROADMAP-WORKFLOW.md`. Sections: spec-driven feature intake (step-by-step), output format expectations (plan.md structure, tasks.md structure, receipts), failure modes + remediation, best practices (clear intents, iterating on spec, splitting multi-feature specs). Depends: sk-validation-rules. Produces: `docs/SPEC-KIT-ROADMAP-WORKFLOW.md`",
      "produces": [],
      "consumes": [],
      "deps": [
        "sk-validation-rules"
