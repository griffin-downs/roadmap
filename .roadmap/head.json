{
  "id": "enforcement-hardening-001",
  "desc": "Enforce invariants to prevent clutter: task list hygiene, design doc commitment, worktree cleanup, DAG documentation.",
  "init": "task-list-enforcement",
  "term": "clutter-prevention-gates",
  "nodes": {
    "task-list-enforcement": {
      "id": "task-list-enforcement",
      "desc": "Enforce task list invariants: no in_progress > 48h without update, no undefined in_progress, completion requires evidence. Auto-flag stale items.",
      "produces": [
        "src/lib/enforcement/task-list-validator.ts",
        "tests/task-list-validator.test.ts"
      ],
      "consumes": [
        ".claude/CLAUDE.md",
        "tasks/"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/enforcement/task-list-validator.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "design-doc-commitment": {
      "id": "design-doc-commitment",
      "desc": "Enforce design docs committed during phase, not end. Pre-commit hook blocks untracked .md files in .roadmap/. Spec/ is version-controlled.",
      "produces": [
        "src/lib/enforcement/design-doc-hook.sh",
        "tests/design-doc-hook.test.ts"
      ],
      "consumes": [
        ".roadmap/task-5-artifact-gates-design.md"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/enforcement/design-doc-hook.sh"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "worktree-cleanup-automation": {
      "id": "worktree-cleanup-automation",
      "desc": "Auto-cleanup stale worktrees. Post-session hook: git worktree prune. Dead agent branches auto-deleted. Orphan detection in git-ops.",
      "produces": [
        "src/lib/enforcement/worktree-cleanup.ts",
        "src/hooks/post-session-cleanup.sh"
      ],
      "consumes": [
        ".claude/worktrees/"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/enforcement/worktree-cleanup.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "dag-documentation-requirement": {
      "id": "dag-documentation-requirement",
      "desc": "Every DAG head.*.json must have documented intent/status. Orphaned DAGs (no head.json in current use) auto-archived to .roadmap/archived/. Pre-commit hook enforces.",
      "produces": [
        "src/lib/enforcement/dag-manifest.ts",
        "tests/dag-manifest.test.ts"
      ],
      "consumes": [
        ".roadmap/head.json"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/enforcement/dag-manifest.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "clutter-prevention-gates": {
      "id": "clutter-prevention-gates",
      "desc": "Integrate all 4 enforcement rules into pre-commit + post-session hooks. Validate: no stale tasks, no untracked design docs, no orphaned worktrees, no undocumented DAGs.",
      "produces": [
        "src/lib/enforcement/index.ts",
        "tests/enforcement-integration.test.ts",
        "clutter-prevention-report.json"
      ],
      "consumes": [
        "src/lib/enforcement/task-list-validator.ts",
        "src/lib/enforcement/design-doc-hook.sh",
        "src/lib/enforcement/worktree-cleanup.ts",
        "src/lib/enforcement/dag-manifest.ts"
      ],
      "deps": [
        "task-list-enforcement",
        "design-doc-commitment",
        "worktree-cleanup-automation",
        "dag-documentation-requirement"
      ],
      "validate": [
        {"type": "artifact-exists", "path": "clutter-prevention-report.json"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    }
  }
}
