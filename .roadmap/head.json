{
  "id": "fr-cli-001",
  "desc": "FR-CLI-001: JSON-native CLI with --human renderers — machine-first stdout, structured errors, schema governance",
  "init": "init",
  "term": "term",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Existing CLI: bin/roadmap.ts with json() helper, chart human output, ad-hoc console.log/error",
      "produces": [
        "bin/roadmap.ts"
      ],
      "consumes": [],
      "deps": [],
      "validate": [
        { "type": "artifact-exists", "target": "bin/roadmap.ts" }
      ],
      "idempotent": true
    },
    "rm-cli-json-envelope": {
      "id": "rm-cli-json-envelope",
      "desc": "Central emit() funnel with JSON envelope (schema_version, ok, cmd, repoRoot, headSha, data/error). Replace all json() calls in bin/roadmap.ts. Define canonical error codes. Write JSON_CONTRACT.md schema doc.",
      "produces": [
        "src/lib/cli-envelope.ts",
        "docs/cli/JSON_CONTRACT.md"
      ],
      "consumes": [
        "bin/roadmap.ts"
      ],
      "deps": ["init"],
      "validate": [
        { "type": "artifact-exists", "target": "src/lib/cli-envelope.ts" },
        { "type": "artifact-exists", "target": "docs/cli/JSON_CONTRACT.md" },
        { "type": "shell", "command": "grep -q 'schema_version' src/lib/cli-envelope.ts" },
        { "type": "shell", "command": "grep -q 'export function emit' src/lib/cli-envelope.ts" },
        { "type": "shell", "command": "npx tsc --noEmit" }
      ],
      "idempotent": true
    },
    "rm-cli-human-renderers": {
      "id": "rm-cli-human-renderers",
      "desc": "Human-readable formatters for each command: plan gallery (table), plan select (summary), position/chart (ASCII), doctor (report). Wire --human and --json flags with correct precedence (default=JSON, --human=text, --json overrides --human).",
      "produces": [
        "src/lib/cli-human.ts"
      ],
      "consumes": [
        "src/lib/cli-envelope.ts",
        "bin/roadmap.ts"
      ],
      "deps": ["rm-cli-json-envelope"],
      "validate": [
        { "type": "artifact-exists", "target": "src/lib/cli-human.ts" },
        { "type": "shell", "command": "grep -q '\\-\\-human' bin/roadmap.ts" },
        { "type": "shell", "command": "npx tsc --noEmit" }
      ],
      "idempotent": true
    },
    "rm-cli-contract-tests": {
      "id": "rm-cli-contract-tests",
      "desc": "Contract test suite asserting: (1) default stdout parses as JSON with envelope fields, (2) --human produces non-JSON text, (3) stderr does not contain JSON payload, (4) exit codes match ok field. Cover orient, chart, plan select, plan status, validate, complete.",
      "produces": [
        "tests/cli-contract.test.ts"
      ],
      "consumes": [
        "src/lib/cli-envelope.ts",
        "src/lib/cli-human.ts",
        "bin/roadmap.ts"
      ],
      "deps": ["rm-cli-human-renderers"],
      "validate": [
        { "type": "artifact-exists", "target": "tests/cli-contract.test.ts" },
        { "type": "shell", "command": "npx vitest run tests/cli-contract.test.ts" }
      ],
      "idempotent": true
    },
    "term": {
      "id": "term",
      "desc": "FR-CLI-001 complete — all commands JSON-native, --human renderers, contract tests passing, schema governance doc",
      "produces": [],
      "consumes": [
        "src/lib/cli-envelope.ts",
        "src/lib/cli-human.ts",
        "tests/cli-contract.test.ts",
        "docs/cli/JSON_CONTRACT.md"
      ],
      "deps": ["rm-cli-contract-tests"],
      "validate": [
        { "type": "shell", "command": "npx tsc --noEmit" },
        { "type": "shell", "command": "npx vitest run tests/cli-contract.test.ts" },
        { "type": "shell", "command": "bin/roadmap orient --note 'term gate' 2>/dev/null | node -e \"const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8')); process.exit(d.schema_version===1?0:1)\"" }
      ],
      "idempotent": true
    }
  }
}
