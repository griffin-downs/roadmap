{
  "id": "fr-custodial-iter-002",
  "desc": "FR-CUSTODIAL-ITER-002: Service Fidelity & Mechanical Enforcement (Recovery + Hardening)",
  "init": "init",
  "term": "term",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Synthetic init — FR-CUSTODIAL-ITER-002 fidelity hardening starts",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "idempotent": false
    },
    "state-recovery": {
      "id": "state-recovery",
      "desc": "Restore missing state artifacts: recreate claims.json from trails, validate state consistency (reads ambient trail.jsonl, completed.json from iter-001)",
      "produces": [
        ".roadmap/claims.json",
        ".roadmap/recovery/state-recovery.json"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/claims.json", ".roadmap/recovery/state-recovery.json"]},
        {"type": "shell", "command": "jq -e '.claims | length > 0' .roadmap/claims.json || true"}
      ],
      "idempotent": false
    },
    "enforcement-schema": {
      "id": "enforcement-schema",
      "desc": "Define enforcement schema: validation rules, state contracts, mechanical check DSL",
      "produces": [
        "src/lib/enforcement/schema.ts",
        ".roadmap/specs/enforcement-schema.json"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/enforcement/schema.ts"]},
        {"type": "shell", "command": "npx tsc --noEmit src/lib/enforcement/schema.ts"}
      ],
      "idempotent": true
    },
    "mechanical-validators": {
      "id": "mechanical-validators",
      "desc": "Implement mechanical validators: artifact-schema, process-invariant, state-transition, concurrent-safety",
      "produces": [
        "src/lib/enforcement/validators.ts",
        "src/lib/enforcement/concurrent-safety.ts"
      ],
      "consumes": [
        "src/lib/enforcement/schema.ts"
      ],
      "deps": ["enforcement-schema"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/enforcement/validators.ts", "src/lib/enforcement/concurrent-safety.ts"]},
        {"type": "shell", "command": "npm run check 2>&1 | grep -q 'src/lib/enforcement' || echo 'OK'"}
      ],
      "idempotent": true
    },
    "concurrent-stress-test": {
      "id": "concurrent-stress-test",
      "desc": "Implement concurrent-stress-testing: parallel node execution, race condition detection, state coherence validation",
      "produces": [
        "tests/concurrent-stress.test.ts",
        ".roadmap/testing/concurrent-stress-results.json"
      ],
      "consumes": [
        "src/lib/enforcement/concurrent-safety.ts"
      ],
      "deps": ["mechanical-validators"],
      "validate": [
        {"type": "artifact-exists", "target": "tests/concurrent-stress.test.ts"},
        {"type": "shell", "command": "npm test -- --include='**/concurrent-stress.test.ts' 2>&1 | tail -5"}
      ],
      "idempotent": true
    },
    "error-recovery-paths": {
      "id": "error-recovery-paths",
      "desc": "Implement error-recovery paths: graceful degradation, repair workflows, breakglass mechanism",
      "produces": [
        "src/lib/enforcement/error-recovery.ts",
        "src/lib/enforcement/breakglass.ts"
      ],
      "consumes": [
        "src/lib/enforcement/schema.ts"
      ],
      "deps": ["enforcement-schema"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/enforcement/error-recovery.ts", "src/lib/enforcement/breakglass.ts"]},
        {"type": "shell", "command": "npm run check"}
      ],
      "idempotent": true
    },
    "fidelity-benchmarks": {
      "id": "fidelity-benchmarks",
      "desc": "Establish fidelity benchmarks: latency targets, error budgets, state coherence SLOs (reads ambient mining/aggregated.json from iter-001)",
      "produces": [
        ".roadmap/fidelity/benchmarks.json",
        ".roadmap/fidelity/slo-targets.json"
      ],
      "consumes": [],
      "deps": ["state-recovery"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/fidelity/benchmarks.json", ".roadmap/fidelity/slo-targets.json"]},
        {"type": "shell", "command": "jq -e '.latency_p99_ms' .roadmap/fidelity/benchmarks.json"}
      ],
      "idempotent": false
    },
    "validation-integration": {
      "id": "validation-integration",
      "desc": "Integrate mechanical validators into CLI: add validate subcommand, enforce on complete, report violations",
      "produces": [
        "src/cli/validate.ts",
        "src/lib/enforcement/cli-integration.ts"
      ],
      "consumes": [
        "src/lib/enforcement/validators.ts"
      ],
      "deps": ["mechanical-validators"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/cli/validate.ts", "src/lib/enforcement/cli-integration.ts"]},
        {"type": "shell", "command": "npm run check"}
      ],
      "idempotent": true
    },
    "large-dag-optimization": {
      "id": "large-dag-optimization",
      "desc": "Optimize large-DAG performance: lazy loading, streaming validation, parallel batch processing",
      "produces": [
        "src/lib/optimization/lazy-load.ts",
        "src/lib/optimization/streaming.ts"
      ],
      "consumes": [],
      "deps": ["mechanical-validators"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/optimization/lazy-load.ts", "src/lib/optimization/streaming.ts"]},
        {"type": "shell", "command": "npm run check"}
      ],
      "idempotent": true
    },
    "fidelity-tests": {
      "id": "fidelity-tests",
      "desc": "Write fidelity tests: SLO verification, error budget checks, coherence assertions",
      "produces": [
        "tests/fidelity.test.ts",
        ".roadmap/testing/fidelity-results.json"
      ],
      "consumes": [
        ".roadmap/fidelity/benchmarks.json",
        "src/lib/enforcement/error-recovery.ts"
      ],
      "deps": ["fidelity-benchmarks", "error-recovery-paths"],
      "validate": [
        {"type": "artifact-exists", "target": "tests/fidelity.test.ts"},
        {"type": "shell", "command": "npm test -- --include='**/fidelity.test.ts'"}
      ],
      "idempotent": true
    },
    "state-enforcement": {
      "id": "state-enforcement",
      "desc": "Enforce state machine contracts: validate transitions, detect illegal states, audit trail verification",
      "produces": [
        "src/lib/enforcement/state-machine.ts",
        "src/lib/enforcement/audit-verification.ts"
      ],
      "consumes": [
        ".roadmap/claims.json",
        "src/lib/enforcement/schema.ts"
      ],
      "deps": ["state-recovery", "enforcement-schema"],
      "validate": [
        {"type": "artifact-exists", "target": ["src/lib/enforcement/state-machine.ts", "src/lib/enforcement/audit-verification.ts"]},
        {"type": "shell", "command": "npm run check"}
      ],
      "idempotent": true
    },
    "integration-test": {
      "id": "integration-test",
      "desc": "Integration test: run full validation suite against complex DAGs, verify all mechanical checks",
      "produces": [
        "tests/integration-enforcement.test.ts",
        ".roadmap/testing/integration-results.json"
      ],
      "consumes": [
        "src/cli/validate.ts",
        "src/lib/enforcement/state-machine.ts",
        "tests/concurrent-stress.test.ts",
        "tests/fidelity.test.ts"
      ],
      "deps": ["validation-integration", "state-enforcement", "concurrent-stress-test", "fidelity-tests"],
      "validate": [
        {"type": "artifact-exists", "target": "tests/integration-enforcement.test.ts"},
        {"type": "shell", "command": "npm test -- --include='**/integration-enforcement.test.ts'"}
      ],
      "idempotent": true
    },
    "hardening-report": {
      "id": "hardening-report",
      "desc": "Generate hardening report: coverage of mechanical checks, fidelity improvements, remaining gaps",
      "produces": [
        ".roadmap/reports/iter2-hardening-report.json",
        ".roadmap/reports/iter2-hardening-summary.md"
      ],
      "consumes": [
        ".roadmap/testing/concurrent-stress-results.json",
        ".roadmap/testing/fidelity-results.json",
        ".roadmap/testing/integration-results.json"
      ],
      "deps": ["integration-test"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/reports/iter2-hardening-report.json", ".roadmap/reports/iter2-hardening-summary.md"]},
        {"type": "shell", "command": "jq -e '.total_checks' .roadmap/reports/iter2-hardening-report.json"}
      ],
      "idempotent": false
    },
    "loop-decision": {
      "id": "loop-decision",
      "desc": "Decide: continue to iteration 3 or finalized hardening complete",
      "produces": [
        ".roadmap/loop/iter2-decision.json"
      ],
      "consumes": [
        ".roadmap/reports/iter2-hardening-report.json"
      ],
      "deps": ["hardening-report"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/loop/iter2-decision.json"},
        {"type": "shell", "command": "jq '.continue_iteration or .complete' .roadmap/loop/iter2-decision.json"}
      ],
      "idempotent": true
    },
    "term": {
      "id": "term",
      "desc": "Synthetic term — FR-CUSTODIAL-ITER-002 complete, service fidelity hardened and enforced",
      "produces": [],
      "consumes": [],
      "deps": ["loop-decision"],
      "validate": [],
      "idempotent": false
    }
  }
}
