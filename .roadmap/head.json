      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "harden-artifact-gates": {
      "id": "harden-artifact-gates",
      "desc": "Integrate ArtifactGates into validation stack. Verify it's used by validateNode() in protocol/validation.ts. No mock needed — it's already real.",
      "produces": [
        "src/lib/roadmap/artifact-gates-integration.ts"
