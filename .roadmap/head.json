{
  "id": "custodial-audit-001",
  "desc": "Custodial governance audit: verify git topology (chatalet + main), enforce workflows, validate system linkage, assess coherence.",
  "init": "audit-git-topology",
  "term": "custodial-synthesis",
  "nodes": {
    "audit-git-topology": {
      "id": "audit-git-topology",
      "desc": "Audit git structure: branch topology (main, chatalet), HEAD positions, commit history alignment with roadmap trail, push/pull consistency.",
      "produces": [
        "git-topology-audit.json"
      ],
      "consumes": [
        ".roadmap/trail.jsonl",
        ".git/HEAD"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "git-topology-audit.json"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "audit-workflow-enforcement": {
      "id": "audit-workflow-enforcement",
      "desc": "Audit enforcement: pre-commit hooks active, commit message validation, test enforcement, linter checks. Verify hooks are not bypassed.",
      "produces": [
        "workflow-enforcement-audit.json"
      ],
      "consumes": [
        ".git/hooks",
        "package.json"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "workflow-enforcement-audit.json"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "audit-system-linkage": {
      "id": "audit-system-linkage",
      "desc": "Audit module linkage: verify all imported modules exist, API contracts match, type safety, no circular deps, mocks aligned to real APIs.",
      "produces": [
        "system-linkage-audit.json"
      ],
      "consumes": [
        "src/lib/roadmap/artifact-gates.ts",
        "src/lib/roadmap/mocks/mock-headsha-recovery.ts",
        "src/lib/roadmap/headsha-recovery.ts",
        ".roadmap/REAL-MODULE-API-AUDIT.md"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "system-linkage-audit.json"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "custodial-synthesis": {
      "id": "custodial-synthesis",
      "desc": "Synthesize audit findings: aggregate topology, enforcement, linkage reports. Identify gaps, unenforced workflows, unlinked systems. Generate governance health scorecard.",
      "produces": [
        "custodial-coherence-report.json"
      ],
      "consumes": [
        "git-topology-audit.json",
        "workflow-enforcement-audit.json",
        "system-linkage-audit.json"
      ],
      "deps": [
        "audit-git-topology",
        "audit-workflow-enforcement",
        "audit-system-linkage"
      ],
      "validate": [
        {"type": "artifact-exists", "path": "custodial-coherence-report.json"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    }
  }
}
