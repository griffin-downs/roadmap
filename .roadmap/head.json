{
  "id": "metaflows-p2",
  "desc": "Phase 2: Optimization + Re-validation (3 parallel flows)",
  "protocolVersion": "1.0.0",
  "version": "1.0",
  "init": "p2-init",
  "term": "p2-optimization-complete",
  "spec": ".specify/specs/metaflows-p1/spec.md",
  "nodes": {
    "p2-init": {
      "id": "p2-init",
      "desc": "Phase 2 init - consume Phase 1 results",
      "produces": ["p2-init.marker"],
      "consumes": [".roadmap/metaflow/intent-metaflow-audit-complete.json"],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "target": "p2-init.marker"}
      ],
      "idempotent": true
    },
    "p2-audit-recovery": {
      "id": "p2-audit-recovery",
      "desc": "Flow 1: Audit recovery - close validation gaps",
      "produces": [".roadmap/metaflow/recovery/p2-recovery-report.json"],
      "consumes": ["p2-init.marker"],
      "deps": ["p2-init"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/recovery/p2-recovery-report.json"}
      ],
      "idempotent": true
    },
    "p2-state-coherence": {
      "id": "p2-state-coherence",
      "desc": "Flow 2: State coherence - corruption detection + hardening",
      "produces": [".roadmap/metaflow/coherence/p2-coherence-report.json"],
      "consumes": ["p2-init.marker"],
      "deps": ["p2-init"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/coherence/p2-coherence-report.json"}
      ],
      "idempotent": true
    },
    "p2-performance-hardening": {
      "id": "p2-performance-hardening",
      "desc": "Flow 3: Performance hardening - optimize P50 + recovery hints",
      "produces": [".roadmap/metaflow/performance/p2-optimization-report.json"],
      "consumes": ["p2-init.marker"],
      "deps": ["p2-init"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/performance/p2-optimization-report.json"}
      ],
      "idempotent": true
    },
    "p2-integration": {
      "id": "p2-integration",
      "desc": "Integration - validate all flows complete",
      "produces": [".roadmap/metaflow/p2-integration-check.json"],
      "consumes": [
        ".roadmap/metaflow/recovery/p2-recovery-report.json",
        ".roadmap/metaflow/coherence/p2-coherence-report.json",
        ".roadmap/metaflow/performance/p2-optimization-report.json"
      ],
      "deps": ["p2-audit-recovery", "p2-state-coherence", "p2-performance-hardening"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/p2-integration-check.json"}
      ],
      "idempotent": true
    },
    "p2-optimization-complete": {
      "id": "p2-optimization-complete",
      "desc": "Phase 2 complete - all optimizations validated",
      "produces": [".roadmap/metaflow/p2-optimization-complete.json"],
      "consumes": [".roadmap/metaflow/p2-integration-check.json"],
      "deps": ["p2-integration"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/p2-optimization-complete.json"}
      ],
      "idempotent": true
    }
  }
}
