{
  "id": "transcript-mining-001",
  "desc": "Cross-session transcript mining: aggregate hooks.log + trail.jsonl, extract patterns, detect anomalies, analyze trends",
  "init": "transcript-aggregator",
  "term": "trend-analysis",
  "nodes": {
    "transcript-aggregator": {
      "id": "transcript-aggregator",
      "desc": "Aggregate and normalize hooks.log + trail.jsonl across all sessions into queryable format",
      "produces": [
        "src/lib/mining/transcript-aggregator.ts",
        "tests/transcript-aggregator.test.ts",
        "transcript-index.jsonl"
      ],
      "consumes": [
        ".roadmap/trail.jsonl",
        "hooks.log"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/mining/transcript-aggregator.ts"},
        {"type": "artifact-exists", "path": "transcript-index.jsonl"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "mining-queries": {
      "id": "mining-queries",
      "desc": "Query interface for transcript analysis: agent latency trends, batch health, drift patterns, protocol violations",
      "produces": [
        "src/lib/mining/query-engine.ts",
        "tests/query-engine.test.ts"
      ],
      "consumes": [
        "transcript-index.jsonl",
        "src/lib/mining/transcript-aggregator.ts"
      ],
      "deps": ["transcript-aggregator"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/mining/query-engine.ts"},
        {"type": "artifact-exists", "path": "tests/query-engine.test.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    },
    "anomaly-detection": {
      "id": "anomaly-detection",
      "desc": "Detect anomalies: unusual latencies, persistence violations, stalled work, protocol mismatches",
      "produces": [
        "src/lib/mining/anomaly-detector.ts",
        "tests/anomaly-detector.test.ts"
      ],
      "consumes": [
        "transcript-index.jsonl",
        "src/lib/mining/query-engine.ts"
      ],
      "deps": ["mining-queries"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/mining/anomaly-detector.ts"},
        {"type": "artifact-exists", "path": "tests/anomaly-detector.test.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 2
    },
    "trend-analysis": {
      "id": "trend-analysis",
      "desc": "Trend analysis: measure improvement over time, identify regressions, forecast scaling limits",
      "produces": [
        "src/lib/mining/trend-analyzer.ts",
        "tests/trend-analyzer.test.ts",
        "trend-report-latest.json"
      ],
      "consumes": [
        "transcript-index.jsonl",
        "src/lib/mining/query-engine.ts",
        "src/lib/mining/anomaly-detector.ts"
      ],
      "deps": ["anomaly-detection"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/mining/trend-analyzer.ts"},
        {"type": "artifact-exists", "path": "trend-report-latest.json"}
      ],
      "idempotent": false,
      "mode": "execute",
      "level": 3
    }
  }
}
