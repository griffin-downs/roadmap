{
  "id": "fix-discovered-iterable",
  "desc": "Guard h.discovered iteration in execution-miner — term nodes have no discovered array",
  "init": "guard-discovered",
  "term": "term",
  "nodes": {
    "guard-discovered": {
      "id": "guard-discovered",
      "desc": "Guard h.discovered iteration",
      "produces": [
        "src/runtime/execution-miner.ts"
      ],
      "consumes": [],
      "deps": [],
      "validate": [
        {
          "type": "shell",
          "command": "pnpm build"
        },
        {
          "type": "shell",
          "command": "grep -q 'h.discovered ?? ' src/runtime/execution-miner.ts"
        }
      ],
      "idempotent": true
    },
    "test-guard": {
      "id": "test-guard",
      "desc": "Regression test for missing discovered/blockers",
      "produces": [
        "tests/execution-intelligence.test.ts"
      ],
      "consumes": [
        "src/runtime/execution-miner.ts"
      ],
      "deps": [
        "guard-discovered"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "npx vitest run tests/execution-intelligence.test.ts --reporter=dot"
        }
      ],
      "idempotent": true
    },
    "term": {
      "id": "term",
      "desc": "Terminal verification",
      "produces": [
        "docs/fix-discovered-iterable-verified.md"
      ],
      "consumes": [
        "src/runtime/execution-miner.ts",
        "tests/execution-intelligence.test.ts"
      ],
      "deps": [
        "test-guard"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "npx vitest run --reporter=dot"
        },
        {
          "type": "shell",
          "command": "pnpm build"
        },
        {
          "type": "shell",
          "command": "npx vitest run tests/execution-intelligence.test.ts --reporter=dot"
        }
      ],
      "idempotent": true
    }
  },
