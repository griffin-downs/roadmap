      "produces": [
        "src/lib/roadmap/mocks/mock-trail-manager.ts"
      ],
      "consumes": [
        "src/lib/roadmap/trail-manager.ts",
        ".roadmap/REAL-MODULE-API-AUDIT.md"
      ],
      "deps": [],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/roadmap/mocks/mock-trail-manager.ts"}
      ],
      "idempotent": true,
      "mode": "execute",
      "level": 1
    },
    "align-dag-switcher": {
      "id": "align-dag-switcher",
