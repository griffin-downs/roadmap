{
  "id": "lib-refactor-001",
  "desc": "src/lib refactoring: consolidate modules, reduce exports, organize by concern",
  "init": "init",
  "term": "intent-lib-refactor-complete",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Current src/lib state (213 files, unrefactored)",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "mode": "execute"
    },
    "audit-lib-structure": {
      "id": "audit-lib-structure",
      "desc": "Deep audit of src/lib: identify consolidation targets, dead code, export surface",
      "produces": [
        ".audit/lib-refactor/structure-audit.json",
        ".audit/lib-refactor/consolidation-targets.md"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "path": ".audit/lib-refactor/structure-audit.json"},
        {"type": "artifact-exists", "path": ".audit/lib-refactor/consolidation-targets.md"}
      ],
      "mode": "execute"
    },
    "consolidate-core-modules": {
      "id": "consolidate-core-modules",
      "desc": "Consolidate related modules: recovery.ts + checkpoint.ts → unified audit module",
      "produces": [
        "src/lib/audit.ts",
        ".audit/lib-refactor/consolidation-1.receipt.json"
      ],
      "consumes": [
        "src/lib/recovery.ts",
        "src/lib/checkpoint.ts",
        "src/lib/audit-trail.ts"
      ],
      "deps": ["audit-lib-structure"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/audit.ts"},
        {"type": "shell", "command": "npm run tsc -- --noEmit 2>&1 | grep -q 'error' && exit 1 || exit 0"}
      ],
      "mode": "execute"
    },
    "reduce-export-surface": {
      "id": "reduce-export-surface",
      "desc": "Hide internal helpers: validation.ts exports only validateNode/validateGraph",
      "produces": [
        "src/lib/validation.ts",
        "src/lib/internal/validation-helpers.ts",
        ".audit/lib-refactor/export-reduction.receipt.json"
      ],
      "consumes": [
        "src/lib/validation.ts"
      ],
      "deps": ["audit-lib-structure"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/validation.ts"},
        {"type": "shell", "command": "grep -c 'export.*function' src/lib/validation.ts | grep -E '^[0-2]$'"}
      ],
      "mode": "execute"
    },
    "remove-dead-code": {
      "id": "remove-dead-code",
      "desc": "Remove unused types/functions: LegacyValidatorSpec, deprecatedOrderFunction, oldParallelOrder",
      "produces": [
        ".archive/lib-deprecated/removed-code.md",
        ".audit/lib-refactor/dead-code.receipt.json"
      ],
      "consumes": [
        "src/lib/protocol.ts"
      ],
      "deps": ["audit-lib-structure"],
      "validate": [
        {"type": "artifact-exists", "path": ".archive/lib-deprecated/removed-code.md"},
        {"type": "shell", "command": "grep -r 'LegacyValidatorSpec\\|deprecatedOrderFunction\\|oldParallelOrder' src/ || exit 0"}
      ],
      "mode": "execute"
    },
    "consolidate-types": {
      "id": "consolidate-types",
      "desc": "All interfaces → src/lib/types.ts (single source of truth)",
      "produces": [
        "src/lib/types.ts",
        ".audit/lib-refactor/types-consolidation.receipt.json"
      ],
      "consumes": [
        "src/lib/protocol.ts",
        "src/lib/validation.ts",
        "src/lib/errors.ts"
      ],
      "deps": ["audit-lib-structure"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/types.ts"},
        {"type": "shell", "command": "grep -c 'export.*interface\\|export.*type' src/lib/types.ts"}
      ],
      "mode": "execute"
    },
    "reorganize-by-concern": {
      "id": "reorganize-by-concern",
      "desc": "High-value: reorganize src/lib/{core,agent,recovery,internal} by responsibility",
      "produces": [
        "src/lib/core/index.ts",
        "src/lib/agent/index.ts",
        "src/lib/recovery/index.ts",
        ".audit/lib-refactor/reorganization.receipt.json"
      ],
      "consumes": [
        "src/lib/"
      ],
      "deps": ["consolidate-core-modules", "reduce-export-surface", "consolidate-types"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/core/index.ts"},
        {"type": "artifact-exists", "path": "src/lib/agent/index.ts"},
        {"type": "artifact-exists", "path": "src/lib/recovery/index.ts"},
        {"type": "shell", "command": "test -d src/lib/internal"}
      ],
      "mode": "execute"
    },
    "update-public-api": {
      "id": "update-public-api",
      "desc": "Update src/lib/index.ts: expose only high-level API (define, verify, check, orient)",
      "produces": [
        "src/lib/index.ts",
        ".audit/lib-refactor/api-cleanup.receipt.json"
      ],
      "consumes": [
        "src/lib/core/index.ts"
      ],
      "deps": ["reorganize-by-concern"],
      "validate": [
        {"type": "artifact-exists", "path": "src/lib/index.ts"},
        {"type": "shell", "command": "grep -c 'export' src/lib/index.ts"}
      ],
      "mode": "execute"
    },
    "verify-no-regressions": {
      "id": "verify-no-regressions",
      "desc": "TypeScript compilation + unit tests pass",
      "produces": [
        ".audit/lib-refactor/test-results.json"
      ],
      "consumes": [],
      "deps": ["update-public-api"],
      "validate": [
        {"type": "shell", "command": "npm run tsc -- --noEmit"}
      ],
      "mode": "execute"
    },
    "intent-lib-refactor-complete": {
      "id": "intent-lib-refactor-complete",
      "desc": "Terminal: src/lib refactoring complete, no regressions, exports reduced, modules organized",
      "produces": [
        ".audit/lib-refactor/RECEIPT.json"
      ],
      "consumes": [
        ".audit/lib-refactor/structure-audit.json",
        ".audit/lib-refactor/consolidation-1.receipt.json",
        ".audit/lib-refactor/export-reduction.receipt.json",
        ".audit/lib-refactor/types-consolidation.receipt.json",
        ".audit/lib-refactor/reorganization.receipt.json",
        ".audit/lib-refactor/api-cleanup.receipt.json",
        ".audit/lib-refactor/test-results.json"
      ],
      "deps": ["verify-no-regressions"],
      "validate": [
        {"type": "artifact-exists", "path": ".audit/lib-refactor/RECEIPT.json"}
      ],
      "mode": "plan"
    }
  }
}
