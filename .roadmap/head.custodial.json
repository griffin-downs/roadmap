{
  "id": "fr-custodial-iter-001",
  "desc": "FR-CUSTODIAL-ITER-001: Self-Improving Custodial Quality Loop (Mining-Driven)",
  "init": "init",
  "term": "term",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Synthetic init — FR-CUSTODIAL-ITER-001 quality loop starts",
      "produces": [],
      "consumes": [],
      "deps": [],
      "validate": [],
      "idempotent": false
    },
    "state-audit": {
      "id": "state-audit",
      "desc": "Scan all DAG state files: head.json, completed.json, claims.json, trail.jsonl",
      "produces": [
        ".roadmap/audits/state-audit.json",
        ".roadmap/audits/state-issues.json"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/audits/state-audit.json", ".roadmap/audits/state-issues.json"]},
        {"type": "shell", "command": "jq '.total_checks' .roadmap/audits/state-audit.json | grep -E '^[0-9]+$'"}
      ],
      "idempotent": true
    },
    "performance-profile": {
      "id": "performance-profile",
      "desc": "Profile CLI command latencies, output sizes, memory usage from mining data",
      "produces": [
        ".roadmap/audits/perf-profile.json",
        ".roadmap/audits/performance-anomalies.json"
      ],
      "consumes": [
        ".roadmap/runs/*/mining.json"
      ],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/audits/perf-profile.json"]},
        {"type": "shell", "command": "jq '.commands_profiled > 0' .roadmap/audits/perf-profile.json"}
      ],
      "idempotent": true
    },
    "coverage-analysis": {
      "id": "coverage-analysis",
      "desc": "Analyze test coverage: identify untested code paths, spec scenarios without tests",
      "produces": [
        ".roadmap/audits/coverage-report.json",
        ".roadmap/audits/coverage-gaps.json"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/audits/coverage-report.json"},
        {"type": "shell", "command": "jq '.coverage_pct >= 0' .roadmap/audits/coverage-report.json"}
      ],
      "idempotent": true
    },
    "consistency-check": {
      "id": "consistency-check",
      "desc": "Cross-validate: completed nodes vs artifacts exist, head.json vs actual DAG structure",
      "produces": [
        ".roadmap/audits/consistency-check.json",
        ".roadmap/audits/divergences.json"
      ],
      "consumes": [
        ".roadmap/audits/state-audit.json"
      ],
      "deps": ["state-audit"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/audits/consistency-check.json"},
        {"type": "shell", "command": "jq '.divergences | length >= 0' .roadmap/audits/consistency-check.json"}
      ],
      "idempotent": true
    },
    "spec-conformance-scan": {
      "id": "spec-conformance-scan",
      "desc": "Validate all DAGs against spec-kit schemas: produces exist, validate rules well-formed",
      "produces": [
        ".roadmap/audits/spec-conformance.json",
        ".roadmap/audits/spec-violations.json"
      ],
      "consumes": [],
      "deps": ["init"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/audits/spec-conformance.json"},
        {"type": "shell", "command": "jq '.dags_scanned > 0' .roadmap/audits/spec-conformance.json"}
      ],
      "idempotent": true
    },
    "mining-aggregation": {
      "id": "mining-aggregation",
      "desc": "Aggregate all mining data: execution traces, command metrics, error logs, timing histograms",
      "produces": [
        ".roadmap/mining/aggregated.json",
        ".roadmap/mining/command-histogram.json",
        ".roadmap/mining/error-summary.json"
      ],
      "consumes": [
        ".roadmap/runs/*/mining.json",
        ".roadmap/audits/perf-profile.json"
      ],
      "deps": ["performance-profile"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/mining/aggregated.json", ".roadmap/mining/command-histogram.json"]},
        {"type": "shell", "command": "jq '.total_commands > 0' .roadmap/mining/aggregated.json"}
      ],
      "idempotent": true
    },
    "improvement-proposals": {
      "id": "improvement-proposals",
      "desc": "Synthesize audit + mining results: generate actionable improvements (code, config, process)",
      "produces": [
        ".roadmap/improvements/proposals.json",
        ".roadmap/improvements/prioritized.json"
      ],
      "consumes": [
        ".roadmap/audits/state-issues.json",
        ".roadmap/audits/coverage-gaps.json",
        ".roadmap/audits/divergences.json",
        ".roadmap/mining/aggregated.json"
      ],
      "deps": ["consistency-check", "coverage-analysis", "mining-aggregation"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/improvements/proposals.json"},
        {"type": "shell", "command": "jq '.proposals | length >= 0' .roadmap/improvements/proposals.json"}
      ],
      "idempotent": true
    },
    "auto-repairs": {
      "id": "auto-repairs",
      "desc": "Apply low-risk improvements automatically: fix orphaned nodes, prune stale claims, clean artifacts",
      "produces": [
        ".roadmap/repairs/applied.json",
        ".roadmap/repairs/rollback-plan.json"
      ],
      "consumes": [
        ".roadmap/improvements/prioritized.json"
      ],
      "deps": ["improvement-proposals"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/repairs/applied.json"},
        {"type": "shell", "command": "jq '.repairs_applied >= 0' .roadmap/repairs/applied.json"}
      ],
      "idempotent": true
    },
    "fidelity-benchmark": {
      "id": "fidelity-benchmark",
      "desc": "Measure service fidelity: uptime, error rates, latency percentiles, spec compliance score",
      "produces": [
        ".roadmap/metrics/fidelity-score.json",
        ".roadmap/metrics/trend.json"
      ],
      "consumes": [
        ".roadmap/mining/aggregated.json",
        ".roadmap/audits/spec-conformance.json",
        ".roadmap/repairs/applied.json"
      ],
      "deps": ["auto-repairs", "spec-conformance-scan"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metrics/fidelity-score.json"},
        {"type": "shell", "command": "jq '.fidelity_pct >= 0 and .fidelity_pct <= 100' .roadmap/metrics/fidelity-score.json"}
      ],
      "idempotent": true
    },
    "iteration-report": {
      "id": "iteration-report",
      "desc": "Synthesize iteration: state before/after, improvements applied, fidelity delta, next actions",
      "produces": [
        ".roadmap/iterations/iteration-001.json",
        "reports/CUSTODIAL-ITERATION-001.md"
      ],
      "consumes": [
        ".roadmap/audits/state-audit.json",
        ".roadmap/repairs/applied.json",
        ".roadmap/metrics/fidelity-score.json",
        ".roadmap/improvements/proposals.json"
      ],
      "deps": ["fidelity-benchmark"],
      "validate": [
        {"type": "artifact-exists", "target": [".roadmap/iterations/iteration-001.json", "reports/CUSTODIAL-ITERATION-001.md"]},
        {"type": "shell", "command": "grep -c 'Iteration\\|Fidelity\\|Improvements' reports/CUSTODIAL-ITERATION-001.md"}
      ],
      "idempotent": true
    },
    "loop-decision": {
      "id": "loop-decision",
      "desc": "Decide: continue iteration or converged? Check fidelity delta, proposal count, error trends",
      "produces": [
        ".roadmap/loop/decision.json"
      ],
      "consumes": [
        ".roadmap/iterations/iteration-001.json",
        ".roadmap/metrics/trend.json"
      ],
      "deps": ["iteration-report"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/loop/decision.json"},
        {"type": "shell", "command": "jq '.continue_iteration or .converged' .roadmap/loop/decision.json"}
      ],
      "idempotent": true
    },
    "term": {
      "id": "term",
      "desc": "Synthetic term — FR-CUSTODIAL-ITER-001 complete, ready to loop or finalize",
      "produces": [],
      "consumes": [],
      "deps": ["loop-decision"],
      "validate": [],
      "idempotent": false
    }
  }
}
