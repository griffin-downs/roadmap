{
  "version": "1.1",
  "description": "gitsafe enforcement rules for hardening-001",
  "denylist": [
    "node_modules/**",
    ".env",
    ".env.local",
    "dist/**",
    "build/**",
    "**/.dev/roadmap/**"
  ],
  "maxBytes": 10485760,
  "auditTrail": true,
  "branchRestrictions": {
    "cliEnforcement": true,
    "allowedBranches": [
      "main"
    ],
    "errorMessage": "gitsafe: file operations only allowed from main branch",
    "main": {
      "readOnly": true,
      "requireReview": true,
      "enforceLinearHistory": true
    }
  },
  "auditEntries": [
    {
      "type": "enforcement-added",
      "ts": "2026-03-03T00:00:00Z",
      "detail": "CLI branch enforcement: all commands except help require main branch"
    },
    {
      "type": "gitsafe-integration",
      "ts": "2026-03-03T00:00:00Z",
      "detail": "File reads routed through gitsafe-loader denylist + maxBytes validation"
    }
  ],
  "allowedFilePatterns": [
    "src/**/*.ts",
    "bin/**",
    ".roadmap/**",
    ".github/**",
    "package.json",
    "tsconfig.json"
  ],
  "consumePattern": {
    "productionClone": "/home/griffin/src/roadmap",
    "developmentClone": "~/src/.dev/roadmap",
    "deniedPaths": [
      "**/.dev/roadmap/**"
    ],
    "enforceFromProductionOnly": true,
    "description": "Only production clone /home/griffin/src/roadmap is safe for consumption"
  }
}
