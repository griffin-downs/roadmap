{
  "version": "1.0",
  "description": "gitsafe enforcement rules",
  "denylist": [
    "node_modules/**",
    ".env",
    ".env.local",
    "dist/**",
    "build/**"
  ],
  "maxBytes": 10485760,
  "auditTrail": true,
  "branchRestrictions": {
    "main": {
      "readOnly": true,
      "requireReview": true,
      "enforceLinearHistory": true
    }
  },
  "allowedFilePatterns": [
    "src/**/*.ts",
    "bin/**",
    ".roadmap/**",
    ".github/**",
    "package.json",
    "tsconfig.json",
    "tsconfig.build.json",
    ".gitignore",
    "specs/**"
  ]
}
