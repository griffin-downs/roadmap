{
  "schemaVersion": 1,
  "id": "optimizer-iter-7",
  "desc": "Optimizer iteration 7",
  "stageMin": 1,
  "stageMax": 5,
  "requiresAuthority": false,
  "steps": [
    {
      "id": "opt-7-mine",
      "cmd": "roadmap internal optimizer-mine",
      "args": {
        "iterN": 7
      },
      "produces": [
        ".roadmap/metaflow-optimizer/iter-7/mining.json"
      ],
      "consumes": [
        ".roadmap/metaflow-optimizer/baseline.json",
        ".roadmap/mining/aggregated.json"
      ],
      "validate": [
        {
          "type": "artifact-exists",
          "target": ".roadmap/metaflow-optimizer/iter-7/mining.json"
        }
      ],
      "desc": "Mine execution data from aggregated.json; detect friction",
      "render": {
        "required": false
      }
    },
    {
      "id": "opt-7-audit",
      "cmd": "roadmap internal optimizer-audit",
      "args": {
        "iterN": 7
      },
      "produces": [
        ".roadmap/metaflow-optimizer/iter-7/audit.json"
      ],
      "consumes": [
        ".roadmap/metaflow-optimizer/iter-7/mining.json"
      ],
      "validate": [
        {
          "type": "artifact-exists",
          "target": ".roadmap/metaflow-optimizer/iter-7/audit.json"
        }
      ],
      "desc": "Audit and categorize friction findings",
      "render": {
        "required": false
      }
    },
    {
      "id": "opt-7-propose",
      "cmd": "roadmap internal optimizer-propose",
      "args": {
        "iterN": 7
      },
      "produces": [
        ".roadmap/metaflow-optimizer/iter-7/proposals.json"
      ],
      "consumes": [
        ".roadmap/metaflow-optimizer/iter-7/audit.json",
        ".roadmap/mining/aggregated.json"
      ],
      "validate": [
        {
          "type": "artifact-exists",
          "target": ".roadmap/metaflow-optimizer/iter-7/proposals.json"
        }
      ],
      "desc": "Generate optimization proposals from friction analysis",
      "render": {
        "required": false
      }
    },
    {
      "id": "opt-7-implement",
      "cmd": "roadmap internal optimizer-implement",
      "args": {
        "iterN": 7
      },
      "produces": [
        ".roadmap/metaflow-optimizer/iter-7/impl.json"
      ],
      "consumes": [
        ".roadmap/metaflow-optimizer/iter-7/proposals.json"
      ],
      "validate": [
        {
          "type": "artifact-exists",
          "target": ".roadmap/metaflow-optimizer/iter-7/impl.json"
        }
      ],
      "desc": "Record top proposal as plan (not code implementation)",
      "render": {
        "required": false
      }
    },
    {
      "id": "opt-7-measure",
      "cmd": "roadmap internal optimizer-measure",
      "args": {
        "iterN": 7
      },
      "produces": [
        ".roadmap/metaflow-optimizer/iter-7/metrics.json"
      ],
      "consumes": [
        ".roadmap/metaflow-optimizer/iter-7/impl.json",
        ".roadmap/metaflow-optimizer/iter-7/mining.json",
        ".roadmap/metaflow/coherence/coherence-report.json",
        ".roadmap/metaflow/recovery/recovery-report.json"
      ],
      "validate": [
        {
          "type": "artifact-exists",
          "target": ".roadmap/metaflow-optimizer/iter-7/metrics.json"
        }
      ],
      "desc": "Measure real metrics; write sentinel if targets met",
      "render": {
        "required": false
      }
    }
  ]
}