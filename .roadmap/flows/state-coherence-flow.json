{
  "schemaVersion": 1,
  "id": "state-coherence-flow",
  "desc": "Validate state machine transitions, detect deadlocks, validate concurrent ordering",
  "stageMin": 0,
  "stageMax": 10,
  "requiresAuthority": true,
  "steps": [
    {
      "id": "step-1-load-transitions",
      "desc": "Load state transitions from audit trail",
      "cmd": "roadmap internal load-transitions",
      "args": {"trailPath": ".roadmap/trail.jsonl"},
      "produces": [".roadmap/metaflow/coherence/transitions.json"],
      "consumes": [],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/coherence/transitions.json"}
      ],
      "render": {"required": true}
    },
    {
      "id": "step-2-verify-sequences",
      "desc": "Verify legal transition sequences",
      "cmd": "roadmap internal verify-transitions",
      "args": {"transitionsPath": ".roadmap/metaflow/coherence/transitions.json"},
      "produces": [".roadmap/metaflow/coherence/transition-validation.json"],
      "consumes": [".roadmap/metaflow/coherence/transitions.json"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/coherence/transition-validation.json"}
      ],
      "render": {"required": true}
    },
    {
      "id": "step-3-detect-deadlocks",
      "desc": "Detect deadlocks and cycles",
      "cmd": "roadmap internal detect-deadlocks",
      "args": {"transitionsPath": ".roadmap/metaflow/coherence/transitions.json"},
      "produces": [".roadmap/metaflow/coherence/deadlock-report.json"],
      "consumes": [".roadmap/metaflow/coherence/transitions.json"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/coherence/deadlock-report.json"}
      ],
      "render": {"required": true}
    },
    {
      "id": "step-4-validate-concurrent",
      "desc": "Validate concurrent operation ordering",
      "cmd": "roadmap internal validate-concurrent",
      "args": {"transitionsPath": ".roadmap/metaflow/coherence/transitions.json", "completedPath": ".roadmap/completed.json"},
      "produces": [".roadmap/metaflow/coherence/concurrent-validation.json"],
      "consumes": [".roadmap/metaflow/coherence/transitions.json"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/coherence/concurrent-validation.json"}
      ],
      "render": {"required": true}
    },
    {
      "id": "step-5-coherence-report",
      "desc": "Generate coherence score and violations report",
      "cmd": "roadmap internal report-coherence",
      "args": {
        "validationPath": ".roadmap/metaflow/coherence/transition-validation.json",
        "deadlockPath": ".roadmap/metaflow/coherence/deadlock-report.json",
        "concurrentPath": ".roadmap/metaflow/coherence/concurrent-validation.json"
      },
      "produces": [".roadmap/metaflow/coherence/coherence-report.json"],
      "consumes": [".roadmap/metaflow/coherence/transition-validation.json", ".roadmap/metaflow/coherence/deadlock-report.json", ".roadmap/metaflow/coherence/concurrent-validation.json"],
      "validate": [
        {"type": "artifact-exists", "target": ".roadmap/metaflow/coherence/coherence-report.json"}
      ],
      "render": {"required": true}
    }
  ]
}
