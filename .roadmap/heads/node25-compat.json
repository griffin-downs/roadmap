{
  "id": "node25-compat",
  "desc": "Add build step for Node 25 compatibility — bundle CLI via esbuild, emit library via tsc, update package.json exports/bin/scripts",
  "init": "init",
  "term": "compat-verified",
  "nodes": {
    "init": {
      "id": "init",
      "desc": "Synthetic init — roots all independent tasks",
      "produces": [
        "init.marker"
      ],
      "consumes": [],
      "deps": [],
      "validate": [],
      "idempotent": true
    },
    "tsconfig-emit": {
      "id": "tsconfig-emit",
      "desc": "Configure tsc to emit JS + declarations to dist/",
      "produces": [
        "tsconfig.build.json"
      ],
      "consumes": [
        "init.marker"
      ],
      "deps": [
        "init"
      ],
      "validate": [
        {
          "type": "artifact-exists"
        },
        {
          "type": "shell",
          "command": "node -e \"const c = JSON.parse(require('fs').readFileSync('tsconfig.build.json','utf8')); if(c.compilerOptions.noEmit !== false) process.exit(1); if(c.compilerOptions.outDir !== 'dist') process.exit(1); if(!c.compilerOptions.declaration) process.exit(1)\""
        }
      ],
      "idempotent": true
    },
    "gitignore-dist": {
      "id": "gitignore-dist",
      "desc": "Add dist/ to .gitignore",
      "produces": [
        ".gitignore"
      ],
      "consumes": [
        "init.marker"
      ],
      "deps": [
        "init"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "grep -q '^dist/' .gitignore"
        }
      ],
      "idempotent": true
    },
    "build-script": {
      "id": "build-script",
      "desc": "Add build script to package.json — tsc for library emit, esbuild for CLI bundle",
      "produces": [
        "package.json"
      ],
      "consumes": [
        "tsconfig.build.json"
      ],
      "deps": [
        "tsconfig-emit"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "node -e \"const p = JSON.parse(require('fs').readFileSync('package.json','utf8')); if(!p.scripts.build) process.exit(1)\""
        }
      ],
      "idempotent": true
    },
    "exports-rewire": {
      "id": "exports-rewire",
      "desc": "Update package.json exports to point at dist/ JS outputs, update bin to dist/roadmap.js",
      "produces": [
        "package.json"
      ],
      "consumes": [
        "package.json"
      ],
      "deps": [
        "build-script"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "node -e \"const p = JSON.parse(require('fs').readFileSync('package.json','utf8')); if(!p.exports['.'].endsWith('.js')) process.exit(1); if(!p.bin.roadmap.includes('dist')) process.exit(1)\""
        }
      ],
      "idempotent": true
    },
    "build-verify": {
      "id": "build-verify",
      "desc": "Run build, verify dist/ outputs exist and CLI executes",
      "produces": [
        ".roadmap/tasks/build-verify.artifact.json"
      ],
      "consumes": [
        "tsconfig.build.json",
        "package.json",
        ".gitignore"
      ],
      "deps": [
        "exports-rewire",
        "gitignore-dist"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "pnpm run build"
        },
        {
          "type": "shell",
          "command": "test -f dist/roadmap.js"
        },
        {
          "type": "shell",
          "command": "test -f dist/src/protocol.js"
        },
        {
          "type": "shell",
          "command": "test -f dist/src/protocol.d.ts"
        },
        {
          "type": "shell",
          "command": "node dist/roadmap.js help"
        }
      ],
      "idempotent": true
    },
    "compat-verified": {
      "id": "compat-verified",
      "desc": "Terminal — full build pipeline works, CLI runs from dist/, library exports resolve to JS",
      "produces": [
        ".roadmap/tasks/compat-verified.artifact.json"
      ],
      "consumes": [],
      "deps": [
        "build-verify"
      ],
      "validate": [
        {
          "type": "shell",
          "command": "pnpm run build && node dist/roadmap.js orient --note 'compat self-test'"
        }
      ],
      "idempotent": true
    }
  },
  "version": "0.3.0",
  "protocolVersion": "0.3.0"
}
