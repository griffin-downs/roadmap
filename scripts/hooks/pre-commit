#!/bin/bash
# Pre-commit hook for governance enforcement
# Runs local validation gates: typecheck + DAG integrity
# Blocks commit if any gate fails
# Override with: git commit --no-verify

set -e

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔍 Pre-commit validation...${NC}"

# Get the project root
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Track failures
FAILED=0

# 1. TypeScript check
echo -e "${YELLOW}  ➤ TypeScript compilation...${NC}"
if npm run check > /tmp/tsc.log 2>&1; then
  echo -e "${GREEN}  ✓ TypeScript${NC}"
else
  echo -e "${RED}  ✗ TypeScript errors:${NC}"
  cat /tmp/tsc.log | head -30
  FAILED=$((FAILED + 1))
fi

# 2. DAG structural integrity
echo -e "${YELLOW}  ➤ DAG structure...${NC}"
if npm run check:dag:define > /tmp/dag.log 2>&1; then
  echo -e "${GREEN}  ✓ DAG integrity${NC}"
else
  echo -e "${RED}  ✗ DAG structural errors:${NC}"
  cat /tmp/dag.log | head -30
  FAILED=$((FAILED + 1))
fi

# Final result
echo ""
if [ $FAILED -eq 0 ]; then
  echo -e "${GREEN}✅ All pre-commit gates passed${NC}"
  exit 0
else
  echo -e "${RED}❌ Pre-commit validation failed ($FAILED gate(s))${NC}"
  echo -e "${YELLOW}💡 Fix the errors above and try again, or use:${NC}"
  echo -e "${YELLOW}   git commit --no-verify${NC} (governance override, use sparingly)"
  exit 1
fi
