#!/bin/bash
# Pre-commit hook: branch discipline + gitsafe denylist + DAG integrity
# Gates: (1) main branch is read-only, (2) head.json locked to feature branches,
#         (3) gitsafe denylist blocks forbidden paths, (4) typecheck, (5) DAG define()

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Pre-commit validation...${NC}"

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

FAILED=0
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || echo "")

# Gate 0: Block direct commits to main/master, allow merge commits (PR workflow)
echo -e "${YELLOW}  > Main branch guard...${NC}"
if [[ "$BRANCH" == "main" ]] || [[ "$BRANCH" == "master" ]]; then
  if [ -f .git/MERGE_HEAD ]; then
    # Merge commit — allow (from feature branch)
    :
  else
    # Direct commit — block
    echo -e "${RED}  x Main branch is read-only${NC}"
    echo ""
    echo -e "${RED}ERROR: Direct commits to '$BRANCH' are blocked. Use: git checkout -b feat/... && git push${NC}"
    echo ""
    exit 1
  fi
fi
echo -e "${GREEN}  + Main branch guard (on: $BRANCH)${NC}"

# Gate 1: head*.json locked to feat/*, wip/*, develop
echo -e "${YELLOW}  > Branch discipline (head.json)...${NC}"
if [ -n "$STAGED_FILES" ]; then
  if echo "$STAGED_FILES" | grep -q '\.roadmap/head.*\.json'; then
    if [[ "$BRANCH" != "feat/"* ]] && [[ "$BRANCH" != "wip/"* ]] && [[ "$BRANCH" != "develop" ]] && [ ! -f .git/MERGE_HEAD ]; then
      echo -e "${RED}  x Branch discipline violation${NC}"
      echo -e "${RED}ERROR: Cannot edit .roadmap/head*.json on branch '$BRANCH'${NC}"
      echo ""
      echo -e "${YELLOW}Only feat/*, wip/*, develop branches may edit head*.json${NC}"
      echo -e "${YELLOW}Fix: roadmap spawn --task <node-id>${NC}"
      FAILED=$((FAILED + 1))
    else
      echo -e "${GREEN}  + Branch discipline${NC}"
    fi
  else
    echo -e "${GREEN}  + Branch discipline${NC}"
  fi
else
  echo -e "${GREEN}  + Branch discipline (no staged files)${NC}"
fi

# Gate 2: Gitsafe denylist compliance
echo -e "${YELLOW}  > Gitsafe denylist...${NC}"
ENFORCEMENT_FILE="$PROJECT_ROOT/.roadmap/enforcement.json"
DENYLIST_VIOLATION=0
if [ -f "$ENFORCEMENT_FILE" ] && [ -n "$STAGED_FILES" ]; then
  DENYLIST=$(jq -r '.denylist[]?' "$ENFORCEMENT_FILE" 2>/dev/null || echo "")
  if [ -n "$DENYLIST" ]; then
    while IFS= read -r file; do
      [ -z "$file" ] && continue
      while IFS= read -r pattern; do
        [ -z "$pattern" ] && continue
        # Convert glob pattern to regex for matching
        REGEX=$(echo "$pattern" | sed 's/\*\*/.*/' | sed 's/\*/.*/g')
        if echo "$file" | grep -qE "^${REGEX}$"; then
          echo -e "${RED}  x Denied: $file (matches denylist: $pattern)${NC}"
          DENYLIST_VIOLATION=1
        fi
      done <<< "$DENYLIST"
    done <<< "$STAGED_FILES"
  fi
fi
if [ "$DENYLIST_VIOLATION" -eq 1 ]; then
  echo -e "${RED}  x Gitsafe denylist violation${NC}"
  FAILED=$((FAILED + 1))
else
  echo -e "${GREEN}  + Gitsafe denylist${NC}"
fi

# Gate 3: TypeScript compilation
echo -e "${YELLOW}  > TypeScript compilation...${NC}"
if npm run check > /tmp/tsc.log 2>&1; then
  echo -e "${GREEN}  + TypeScript${NC}"
else
  echo -e "${RED}  x TypeScript errors:${NC}"
  head -30 /tmp/tsc.log
  FAILED=$((FAILED + 1))
fi

# Gate 4: DAG structural integrity (main/merge only — gitsafe blocks on feature branches)
echo -e "${YELLOW}  > DAG structure...${NC}"
if [ -f .git/MERGE_HEAD ]; then
  echo -e "${GREEN}  + DAG integrity (skipped: merge commit)${NC}"
elif [[ "$BRANCH" == "main" ]] || [[ "$BRANCH" == "master" ]]; then
  if npm run check:dag:define > /tmp/dag.log 2>&1; then
    echo -e "${GREEN}  + DAG integrity${NC}"
  else
    echo -e "${RED}  x DAG structural errors:${NC}"
    head -30 /tmp/dag.log
    FAILED=$((FAILED + 1))
  fi
else
  echo -e "${GREEN}  + DAG integrity (skipped: feature branch)${NC}"
fi

# Gate 5: DAG origin validation (spec-origin.json must exist when head.json staged)
echo -e "${YELLOW}  > DAG origin...${NC}"
if [ -n "$STAGED_FILES" ] && echo "$STAGED_FILES" | grep -q '\.roadmap/head.*\.json'; then
  if [ -f .git/MERGE_HEAD ]; then
    echo -e "${GREEN}  + DAG origin (skipped: merge commit)${NC}"
  elif npx tsx scripts/validate-dag-origin.ts "$PROJECT_ROOT" 2>/tmp/dag-origin.log; then
    echo -e "${GREEN}  + DAG origin${NC}"
  else
    echo -e "${RED}  x DAG origin validation failed${NC}"
    cat /tmp/dag-origin.log >&2
    FAILED=$((FAILED + 1))
  fi
else
  echo -e "${GREEN}  + DAG origin (no head.json staged)${NC}"
fi

# Result
echo ""
if [ $FAILED -eq 0 ]; then
  echo -e "${GREEN}All pre-commit gates passed${NC}"
  exit 0
else
  echo -e "${RED}Pre-commit validation failed ($FAILED gate(s))${NC}"
  echo -e "${YELLOW}Fix the errors above. Override: git commit --no-verify${NC}"
  exit 1
fi
