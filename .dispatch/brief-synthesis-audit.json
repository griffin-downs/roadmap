{
  "agentId": "synthesis-audit-agent",
  "nodeId": "synthesis-audit",
  "dagId": "roadmap-audit-enforcement-001",
  "dagPath": ".roadmap/head.candidate.json",
  "position": {
    "nodeId": "synthesis-audit",
    "batch": 2,
    "level": 2
  },
  "mode": "execute",
  "description": "Aggregate audit findings into enforcement strategy",
  "produces": [".roadmap/audit-synthesis.json"],
  "consumes": ["docs/PROTOCOL-AUDIT.md", "docs/VALIDATION-GAPS.md"],
  "dependencies": ["audit-protocol", "audit-validation"],
  "validate": [
    {
      "type": "artifact-exists",
      "path": ".roadmap/audit-synthesis.json"
    }
  ],
  "instructions": {
    "intent": "Read audit findings from protocol + validation audits. Synthesize into a coherent enforcement strategy that identifies the top gaps and priority order for remediation. Produce JSON with structured findings, impact analysis, and implementation roadmap.",
    "acceptance_criteria": [
      ".roadmap/audit-synthesis.json exists",
      "JSON structure: { findings: [], priorities: [], roadmap: [] }",
      "findings: cross-referenced from both audits with impact ratings",
      "priorities: ranked by severity × ease, with estimated effort",
      "roadmap: implementation sequence accounting for dependencies"
    ],
    "context": {
      "repoRoot": "/home/griffin/src/roadmap",
      "inputFiles": ["docs/PROTOCOL-AUDIT.md", "docs/VALIDATION-GAPS.md"],
      "schema": {
        "findings": [
          {
            "id": "string",
            "source": "audit-protocol | audit-validation",
            "severity": "critical | high | medium | low",
            "impact": "string",
            "affectedComponent": "string"
          }
        ],
        "priorities": [
          {
            "findingId": "string",
            "rank": "number",
            "estimatedEffort": "hours",
            "rationale": "string"
          }
        ],
        "roadmap": [
          {
            "phase": "number",
            "tasks": ["string"],
            "nodeIds": ["string"],
            "duration": "string"
          }
        ]
      }
    }
  }
}
